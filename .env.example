# === Required ===
DB_PASSWORD=changeme_strong_password_here

# === Network Scanning ===
NETWORK_CIDR=192.168.1.0/24

# === Authentication (JWT) ===
# Generate with: openssl rand -hex 32
JWT_SECRET=

# === NVD API (EPSS + CVE Lookups) ===
# Get a free key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# === Webhook Integrations ===
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# === Firmware Storage (S3-compatible) ===
S3_ENDPOINT=
S3_BUCKET=ironmesh-firmware
S3_ACCESS_KEY=
S3_SECRET_KEY=
